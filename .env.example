# Supabase - use NEW publishable & secret keys (not legacy anon/service_role)
# See: https://supabase.com/docs/guides/api/api-keys
# API Keys tab: Publishable key (sb_publishable_...) for client, Secret key (sb_secret_...) for server
# For Google Auth: enable Google in Auth → Providers, add redirect: http://localhost:3000/auth/callback
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=   # Publishable key (sb_publishable_...) - safe for client
SUPABASE_SERVICE_ROLE_KEY=       # Secret key (sb_secret_...) - NEVER commit real value
DATABASE_URL=

# Slack
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# Zoom
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_VERIFICATION_TOKEN=

# Google (Workspace + Gmail)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# LinkedIn
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Upstash Redis (BullMQ)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
REDIS_URL=

# AI
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Dodo Payments
DODO_API_KEY=
DODO_WEBHOOK_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
CRON_SECRET=

# Resend (optional - for Supabase Auth emails)
# Configure in Supabase Dashboard → Auth → SMTP Settings
# Host: smtp.resend.com | Port: 465 | User: resend | Password: API key from resend.com/api-keys
